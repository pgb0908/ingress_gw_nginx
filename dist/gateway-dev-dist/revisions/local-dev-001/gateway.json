{
  "apiVersion": "iip.gateway/v1alpha1",
  "kind": "Gateway",
  "metadata": {
    "name": "local-gateway"
  },
  "spec": {
    "logging": {
      "accessLog": {
        "enabled": true,
        "format": "JSON"
      }
    },
    "tracing": {
      "enabled": true
    },
    "metrics": {
      "enabled": true,
      "path": "/metrics",
      "port": 19090
    }
  }
}
